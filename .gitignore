# Rust / Cargo
/target/
docker-bin/
**/*.rs.bk
*.pdb

# Cargo.lock: commit for binaries, ignore for libraries.
# Default here assumes binary; remove the next line if this becomes a library crate.
# Cargo.lock

# IDE / editor
.idea/
.vscode/
*.swp

# Env
.env
.env.local

# Claude Code local-only files
.claude/settings.local.json
.claude/local/
.claude/.credentials*
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# macOS
.DS_Store

# Credential bundles — issued by `provision-client` and contain bearer
# tokens; never source of truth, never check in. Match anywhere in the tree.
*.bundle.json

# 006-management-web-ui: SPA build artefacts and Node module cache.
# Keep `webui/dist/` itself (so rust-embed can compile against an empty
# directory under PORTUNUS_SKIP_WEBUI=1) but ignore its contents.
webui/dist/*
!webui/dist/.gitkeep
webui/node_modules/
webui/playwright-report/
webui/test-results/
webui/.eslintcache
