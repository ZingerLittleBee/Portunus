{
  "name": "portunus-webui",
  "private": true,
  "version": "1.7.0",
  "type": "module",
  "description": "Operator Web UI for portunus-server (006-management-web-ui).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && size-limit",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "5.4.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-virtual": "3.14.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "i18next": "26.3.0",
    "lucide-react": "1.17.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "react-i18next": "17.0.8",
    "react-router-dom": "7.16.0",
    "recharts": "3.8.1",
    "shadcn": "^4.10.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@size-limit/preset-app": "12.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "agentation": "^3.0.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "20.9.0",
    "postcss": "8.5.15",
    "react-grab": "^0.1.44",
    "rollup-plugin-visualizer": "7.0.1",
    "size-limit": "12.1.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "size-limit": [
    {
      "name": "main bundle (gzip)",
      "path": "dist/assets/index-*.js",
      "limit": "500 KB",
      "gzip": true
    }
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@tanstack/react-virtual>react": "19",
        "@tanstack/react-virtual>react-dom": "19"
      }
    }
  }
}
