# forward-rs server configuration (v0.4.0).
# Used by `forward-server --config /etc/forward/server.toml serve`.
# Defaults match the deploy/systemd/forward-server.service layout.
# Schema: see crates/forward-core/src/config.rs (ServerConfig).

# gRPC control-plane listener — clients dial this address.
# Bind to 0.0.0.0 for cross-host clients, or to a specific interface
# (e.g. "10.0.0.5:7443") to restrict reachability. Loopback is fine for
# co-located server+client testing.
control_listen = "0.0.0.0:7443"

# Operator HTTP API (provision-client / push-rule / list-rules / rule-stats).
# MUST stay on loopback: there is no per-request auth — the API trusts
# anyone with shell access to the server host. Enforced at startup.
operator_http_listen = "127.0.0.1:7080"

# Prometheus /metrics endpoint. Same loopback constraint.
# Scrape by running prometheus on the same host (or a sidecar).
metrics_listen = "127.0.0.1:7081"

# Self-signed TLS material. Both files are auto-generated on first run
# if missing. The cert SAN includes hostname + "localhost" + 127.0.0.1
# only — for routable deployments, replace these with operator-managed
# materials whose SAN covers the address(es) clients will dial.
# server.key MUST be mode 0600 (the loader rejects looser perms).
tls_cert_path = "/var/lib/forward/server.crt"
tls_key_path = "/var/lib/forward/server.key"

# Bearer-token store. Created on first `provision-client`. Mode 0600.
# Tokens are 256-bit random secrets; keep this file backed up.
token_store_path = "/var/lib/forward/tokens.json"

# Graceful drain timeout for forwarded connections on SIGINT/SIGTERM.
# In-flight rules get up to this many seconds to finish before the
# kernel reaps remaining sockets. Match the systemd unit's
# TimeoutStopSec to avoid kill -9 mid-drain.
shutdown_drain_timeout_secs = 30

# Log format: "json" (default — structured) or "compact".
# Production: keep "json" so logs ship cleanly to a collector.
# Local dev: switch to "compact" for human readability.
log_format = "json"

# Maximum ports a single port-range rule may span (002-port-range-forward).
# Default: 1024. Each port in a range consumes one TCP listener (one fd) on
# the client; the cap exists so an operator typo can't burst the client's
# RLIMIT_NOFILE. Raise only after raising LimitNOFILE in the systemd unit
# accordingly (see deploy/systemd/forward-{server,client}.service).
# range_rule_max_ports = 1024

# UDP forwarding tunables (004-udp-forward, v0.4.0+). Surfaced to the
# client over the Welcome message so clients always run with the
# server-configured values. Both keys are optional; absence (or `0` on
# the wire) means "use the compile-time default".
#
# Idle window before a per-flow upstream socket is reaped. Range:
# 30..=300 (the validator rejects values outside this band). Default:
# 60 s. Lower values reclaim faster but can sever long-tail flows
# (e.g. WireGuard handshake intervals); raise on workloads with very
# bursty re-use of source ports.
# udp_flow_idle_secs = 60
#
# Per-rule cap on simultaneous live UDP flows. Range: 1..=65535.
# Default: 1024. The cap activates `forward_rule_flows_dropped_overflow_total`
# when sustained churn from many distinct source ports exceeds the
# ceiling — those drops are recorded; existing flows are NEVER evicted
# to make room (idle eviction handles steady-state shrinkage). Raise
# alongside the client's LimitNOFILE if your traffic legitimately
# needs more concurrent end-user sources.
# udp_max_flows_per_rule = 1024

# DNS resolver tunables (003-domain-name-forward, v0.3.0+).
# Reserved for future operator overrides. The current release bakes
# the spec-fixed defaults into ResolverConfig (client-side):
#   - cache_floor              = 5 s     (TTL clamp lower bound)
#   - cache_ceiling            = 5 min   (TTL clamp upper bound)
#   - stale_while_error_grace  = 30 s    (RFC 8767-style grace)
#   - attempt_timeout          = 3 s     (per-resolver-attempt budget)
#   - negative_cache_retry     = 3 s     (gap after grace expiry)
#   - max_concurrent_resolves  = 64      (Pending-state ceiling)
# No keys land in this file in v0.3.0; if a future release exposes
# any of the above as operator-tunable, expect them under a
# `[resolver]` table here.
